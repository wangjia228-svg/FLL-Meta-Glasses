<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F2F5FB">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1B2A4A"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@android:color/white" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MARP"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="New Field Record"
                android:textColor="#A0B0CC"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvStepIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="In Progress"
            android:textColor="#A0B0CC"
            android:textSize="12sp"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnHandsFreeToggle"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="&#127908; OFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#555555"
            style="@style/Widget.MaterialComponents.Button" />
    </LinearLayout>

    <!-- Hands-Free Active Banner -->
    <TextView
        android:id="@+id/tvHandsFreeBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="&#127908;  HANDS-FREE ACTIVE"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingVertical="12dp"
        android:background="#22AA22"
        android:letterSpacing="0.03"
        android:visibility="gone" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- GLASSES CONNECTION step -->
            <TextView
                android:id="@+id/tvConnectLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GLASSES CONNECTION"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#8A9BB5"
                android:letterSpacing="0.12"
                android:layout_marginBottom="8dp" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cardConnect"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvConnectStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Connect your Meta glasses to continue."
                        android:textSize="14sp"
                        android:textColor="#3D7EE8"
                        android:gravity="center"
                        android:layout_marginBottom="12dp" />

                    <Button
                        android:id="@+id/btnConnect"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Connect to Meta Glasses"
                        android:textSize="14sp"
                        android:backgroundTint="#3D7EE8" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- GLASSES PHOTO label — hidden while photo taking is disabled -->
            <TextView
                android:id="@+id/tvPhotoStepLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GLASSES PHOTO"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#8A9BB5"
                android:letterSpacing="0.12"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <!-- Photo card (visible from start) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardPhoto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Status text — hidden while photo taking is disabled -->
                    <TextView
                        android:id="@+id/tvPhotoStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Take a photo with your glasses to continue."
                        android:textSize="14sp"
                        android:textColor="#3D7EE8"
                        android:gravity="center"
                        android:layout_marginBottom="12dp"
                        android:visibility="gone" />

                    <!-- Thumbnail (shown after photo arrives) -->
                    <ImageView
                        android:id="@+id/ivPhoto"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:scaleType="centerCrop"
                        android:background="#E8EDF4"
                        android:contentDescription="Glasses photo"
                        android:visibility="gone" />

                    <!-- SDK camera trigger button — hidden while photo taking is disabled -->
                    <Button
                        android:id="@+id/btnTakePhoto"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Take Photo via Glasses Camera"
                        android:textSize="14sp"
                        android:backgroundTint="#3D7EE8"
                        android:layout_marginTop="8dp"
                        android:visibility="gone" />

                    <!-- Manual import / fallback button — hidden while photo taking is disabled -->
                    <Button
                        android:id="@+id/btnImportPhoto"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Use Last Synced Photo"
                        android:textSize="14sp"
                        android:layout_marginTop="8dp"
                        android:backgroundTint="#1B2A4A"
                        android:visibility="gone" />

                    <!-- Metadata: date/time and GPS -->
                    <LinearLayout
                        android:id="@+id/layoutMetadata"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="12dp"
                        android:visibility="gone">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#EEF1F8"
                            android:layout_marginBottom="10dp" />

                        <TextView
                            android:id="@+id/tvDateTime"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Date/Time: --"
                            android:textSize="13sp"
                            android:textColor="#4A5568"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvLocation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="GPS: Acquiring..."
                            android:textSize="13sp"
                            android:textColor="#4A5568" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Voice Questions label (hidden until questions flow starts) -->
            <TextView
                android:id="@+id/tvVoiceQuestionsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VOICE QUESTIONS"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#8A9BB5"
                android:letterSpacing="0.12"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cardVoiceQuestions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:id="@+id/tvProgressText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Question 1 of 5"
                            android:textSize="12sp"
                            android:textColor="#8A9BB5" />

                        <TextView
                            android:id="@+id/tvVoiceStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ready"
                            android:textSize="12sp"
                            android:textColor="#3D7EE8" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvCurrentQuestion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Waiting to start..."
                        android:textSize="16sp"
                        android:textColor="#1B2A4A"
                        android:textStyle="bold"
                        android:background="#F2F5FB"
                        android:padding="14dp"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tvQuestionDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="13sp"
                        android:textColor="#666666"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="8dp"
                        android:visibility="gone" />

                    <Button
                        android:id="@+id/btnRetryListen"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Retry / Listen Again"
                        android:backgroundTint="#3D7EE8"
                        android:visibility="gone" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Field Notes (populated as questions answered, no step label) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardFieldNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvFieldNotes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="13sp"
                        android:fontFamily="monospace"
                        android:textColor="#2D3748"
                        android:lineSpacingMultiplier="1.5" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Save Button -->
            <Button
                android:id="@+id/btnSaveRecord"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Save Field Record"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="24dp"
                android:backgroundTint="#E67E22"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
