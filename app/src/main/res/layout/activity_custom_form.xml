<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F4FA">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1B2A4A"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&#8592;"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:background="@android:color/transparent"
            android:minWidth="0dp"
            android:paddingStart="0dp"
            android:paddingEnd="8dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Custom Field Form"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <!-- ── Setup section ─────────────────────────────────────────────────── -->
    <ScrollView
        android:id="@+id/scrollSetup"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Set Up Your Form"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#1B2A4A"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Download the template, fill in your questions, then upload it. After confirming, New Field Record will use your questions."
                        android:textSize="14sp"
                        android:textColor="#555555"
                        android:layout_marginBottom="20dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CSV format:"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginBottom="8dp" />

                    <!-- Format table -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="#EEF1F8"
                        android:padding="8dp"
                        android:layout_marginBottom="8dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:background="#D0D8EC"
                            android:padding="6dp">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.8"
                                android:text="" android:textSize="11sp" android:textStyle="bold" android:textColor="#1B2A4A" />
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                                android:text="Question Label" android:textSize="11sp" android:textStyle="bold" android:textColor="#1B2A4A" />
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2"
                                android:text="Description" android:textSize="11sp" android:textStyle="bold" android:textColor="#1B2A4A" />
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.8"
                                android:text="Type" android:textSize="11sp" android:textStyle="bold" android:textColor="#1B2A4A" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:padding="6dp" android:background="#FFFFFF">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.8"
                                android:text="Question #1" android:textSize="11sp" android:textColor="#888888" />
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                                android:text="" android:textSize="11sp" />
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2"
                                android:text="" android:textSize="11sp" />
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.8"
                                android:text="" android:textSize="11sp" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:padding="6dp" android:background="#F7F9FC">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.8"
                                android:text="Question #2" android:textSize="11sp" android:textColor="#888888" />
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                                android:text="" android:textSize="11sp" />
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2"
                                android:text="" android:textSize="11sp" />
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.8"
                                android:text="" android:textSize="11sp" />
                        </LinearLayout>

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="The template has 20 rows — add more if needed."
                        android:textSize="12sp"
                        android:textColor="#888888"
                        android:layout_marginBottom="20dp" />

                    <Button
                        android:id="@+id/btnImportCsv"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Upload CSV"
                        android:textSize="16sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#2D7D46"
                        android:layout_marginBottom="12dp" />

                    <Button
                        android:id="@+id/btnDownloadTemplate"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Download CSV Template"
                        android:textSize="14sp"
                        android:textColor="#1B6BC0"
                        android:backgroundTint="#DCE8F8" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- ── Preview section ───────────────────────────────────────────────── -->
    <ScrollView
        android:id="@+id/scrollPreview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Review Your Form"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#1B2A4A"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvPreviewCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginBottom="16dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:id="@+id/layoutPreviewQuestions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp" />

            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/btnConfirmTemplate"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Confirm &#38; Save"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2D7D46"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnBackToUpload"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Go Back"
                android:textSize="14sp"
                android:textColor="#666666"
                android:backgroundTint="@android:color/transparent" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
