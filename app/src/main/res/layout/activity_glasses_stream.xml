<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1B2A4A"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="40dp"
        android:paddingBottom="16dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="← Back"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2A3E63"
            style="@style/Widget.MaterialComponents.Button" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Livestream"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvStreamStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stopped"
            android:textSize="12sp"
            android:textColor="#A0B0CC" />
    </LinearLayout>

    <!-- Video preview — fills remaining space -->
    <ImageView
        android:id="@+id/ivStream"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scaleType="fitCenter"
        android:background="#111111" />

    <!-- Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1B2A4A"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="16dp">

        <!-- Frame counter -->
        <TextView
            android:id="@+id/tvFrameCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Frames: 0"
            android:textColor="#A0B0CC"
            android:textSize="12sp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="12dp" />

        <!-- Start / Stop buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnStartStream"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Start Stream"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#22AA22"
                style="@style/Widget.MaterialComponents.Button" />

            <Button
                android:id="@+id/btnStopStream"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Stop Stream"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#AA2222"
                android:enabled="false"
                style="@style/Widget.MaterialComponents.Button" />
        </LinearLayout>

        <!-- YouTube streaming section -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2A3E63"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvYouTubeStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="YouTube: Not streaming"
            android:textSize="12sp"
            android:textColor="#A0B0CC"
            android:gravity="center"
            android:layout_marginBottom="6dp" />

        <Button
            android:id="@+id/btnShareStream"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="Share Link"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1565C0"
            android:visibility="gone"
            android:layout_marginBottom="8dp"
            style="@style/Widget.MaterialComponents.Button" />

        <Button
            android:id="@+id/btnYouTubeStream"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="&#127910; Stream to YouTube"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#CC0000"
            style="@style/Widget.MaterialComponents.Button" />
    </LinearLayout>

</LinearLayout>
