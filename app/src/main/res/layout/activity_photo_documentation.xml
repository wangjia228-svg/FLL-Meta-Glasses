<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F2F5">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#27ae60"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@android:color/white" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Photo Documentation"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp" />

        <Button
            android:id="@+id/btnHandsFreeToggle"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="&#127908; OFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#555555"
            style="@style/Widget.MaterialComponents.Button" />
    </LinearLayout>

    <!-- Hands-Free Active Banner -->
    <TextView
        android:id="@+id/tvHandsFreeBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="&#127908;  HANDS-FREE ACTIVE — Say &quot;take photo&quot; to capture"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingVertical="12dp"
        android:background="#22AA22"
        android:letterSpacing="0.03"
        android:visibility="gone" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Photo Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Field Photo"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginBottom="10dp" />

                    <ImageView
                        android:id="@+id/ivPhoto"
                        android:layout_width="match_parent"
                        android:layout_height="220dp"
                        android:scaleType="centerCrop"
                        android:background="#D0D0D0"
                        android:contentDescription="Field photo" />

                    <Button
                        android:id="@+id/btnTakePhoto"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Take Photo"
                        android:textSize="16sp"
                        android:layout_marginTop="12dp"
                        android:backgroundTint="#27ae60" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Metadata Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardMetadata"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Auto-Recorded Info"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:id="@+id/tvDateTime"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Date/Time: --"
                        android:textSize="14sp"
                        android:textColor="#444444"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/tvLocation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Location: Getting GPS..."
                        android:textSize="14sp"
                        android:textColor="#444444" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Voice Questions Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardVoiceQuestions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Voice Documentation"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:id="@+id/tvCurrentQuestion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Starting voice questions..."
                        android:textSize="15sp"
                        android:textColor="#333333"
                        android:background="#E8F5E9"
                        android:padding="12dp"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tvVoiceStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Preparing..."
                        android:textSize="13sp"
                        android:textColor="#888888"
                        android:gravity="center" />

                    <Button
                        android:id="@+id/btnRetryListen"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Retry / Listen Again"
                        android:layout_marginTop="8dp"
                        android:backgroundTint="#667eea"
                        android:visibility="gone" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Field Notes Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Field Notes"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:id="@+id/tvFieldNotes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="13sp"
                        android:fontFamily="monospace"
                        android:textColor="#333333"
                        android:background="#F9F9F9"
                        android:padding="10dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Save Button -->
            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Save Record"
                android:textSize="16sp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="#e67e22"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
